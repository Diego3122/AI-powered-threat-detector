# Template only. Copy to `.env`, replace every placeholder with private values, and never commit the populated file.
# This file is safe to publish because it contains placeholders only.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=threat_detector

JWT_SECRET_KEY=change-me-to-a-long-random-string
INTERNAL_API_KEY=change-me-internal-api-key
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
VITE_API_URL=http://localhost:8000
MODEL_TYPE=structured
TFIDF_MODEL_PATH=models/baseline_unsw.pkl
DEVICE=cpu
KAFKA_BOOTSTRAP=127.0.0.1:9092
WINDOW_MS=10000
# DETECTION_THRESHOLD: operational alert threshold passed to the detector (--threshold flag).
# Overrides the model's trained threshold (stored in the .pkl bundle).
# The UNSW-NB15 structured baseline was trained with threshold=0.2788 (positive-F1-optimal),
# which produces ~49 % FP rate on benign traffic. 0.5 is a sensible operational starting point
# that reduces FP rate significantly while keeping high attack recall (~90 %).
# Retrain with metric="macro_f1" to bake a balanced threshold into the bundle itself.
DETECTION_THRESHOLD=0.5

# Security note: only non-secret frontend configuration should use VITE_* variables.
# Keep JWT secrets, demo user passwords, database credentials, and API keys server-side only.

# Optional auth behavior for local development only
ENABLE_DEMO_USERS=true
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEMO_ADMIN_PASSWORD=change-me-admin
DEMO_ANALYST_PASSWORD=change-me-analyst
DEMO_VIEWER_PASSWORD=change-me-viewer
